<section class="py-28 lg:py-40 bg-space border-y border-slate/70">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="border border-slate/70 bg-slate/20 p-8 lg:p-14" data-reveal>
      <div class="max-w-4xl">
        <p class="text-xs uppercase tracking-[0.24em] text-cyan mb-8" data-scramble="Contact">Contact</p>
        <h2 data-i18n="cta-h2" class="text-cloud font-bold text-3xl lg:text-5xl leading-[1.25] tracking-tight max-w-3xl">
          つくることより、
          <br class="hidden sm:block" />
          成果を出すことに、時間を使う。
        </h2>
        <p data-i18n="cta-p" class="mt-8 text-cloud/70 text-sm lg:text-base leading-relaxed max-w-3xl">
          目的と期限を最初に定義し、必要な施策を必要な順番で実装します。制作会社ではなく、成果責任を持つ実装パートナーとして伴走します。
        </p>

        <div class="mt-10 h-px w-full bg-accent/20"></div>

        <div class="mt-10 flex flex-col md:flex-row md:items-center md:justify-between gap-7">
          <a
            href="/contact"
            class="btn-magnetic inline-flex items-center justify-center gap-3 rounded-sm bg-azure text-space px-8 py-4 font-semibold hover:bg-aozora-600 transition-colors duration-300 min-w-[250px] shadow-[0_4px_20px_rgba(255,198,79,0.3)] hover:shadow-[0_6px_28px_rgba(255,198,79,0.45)]"
          >
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 43.64 33.21" fill="currentColor"><path d="M38.32,0h-33A5.34,5.34,0,0,0,0,5.34V27.88a5.34,5.34,0,0,0,5.34,5.33h33a5.33,5.33,0,0,0,5.33-5.33V5.35A5.33,5.33,0,0,0,38.32,0Zm2.9,27.88a2.9,2.9,0,0,1-2.9,2.9h-33a2.9,2.9,0,0,1-2.9-2.9V5.35a2.9,2.9,0,0,1,2.9-2.9h33a2.9,2.9,0,0,1,2.9,2.9V27.88Z"/><path d="M27.53,16.33,38.2,6.75a1.22,1.22,0,1,0-1.63-1.81L21.84,18.15,19,15.59a0,0,0,0,1,0,0l-.2-.17L7.07,4.93A1.22,1.22,0,0,0,5.45,6.75l10.8,9.66L5.49,26.48a1.22,1.22,0,0,0,.84,2.11,1.23,1.23,0,0,0,.83-.32L18.08,18.05l3,2.65a1.2,1.2,0,0,0,.81.3,1.22,1.22,0,0,0,.82-.31l3-2.73L36.57,28.27a1.18,1.18,0,0,0,.83.34,1.22,1.22,0,0,0,.84-2.11Z"/></svg>
            <span data-i18n="cta-btn">無料相談を申し込む</span>
          </a>

          <div class="space-y-1 md:text-right">
            <a
              href="tel:0989896318"
              data-i18n="cta-call"
              class="block text-cloud text-base lg:text-lg font-medium hover:text-cyan transition-colors"
            >
              098-989-6318 に電話する
            </a>
            <div data-i18n="cta-hours" class="text-cloud/55 text-xs lg:text-sm leading-relaxed">
              平日 9:00-18:00 / 初回ご相談・お見積り無料
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
