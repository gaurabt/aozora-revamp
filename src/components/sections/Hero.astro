---
---

<section data-hero class="relative min-h-[100svh] overflow-hidden">

  <!-- Gradient orbs -->
  <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-3" aria-hidden="true"></div>

  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      data-hero-bg
      src="/header.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-space/70 via-space/82 to-space/95"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-10 pt-40 pb-32 lg:pt-56 lg:pb-40 min-h-[100svh] flex items-center">
    <div class="max-w-4xl">

      <!-- Eyebrow -->
      <p
        data-hero-eyebrow
        class="text-xs uppercase tracking-[0.28em] text-cyan mb-6 font-medium opacity-0"
      >
        Aozora Co., Ltd. &nbsp;／&nbsp; 株式会社青空
      </p>

      <h1
        data-hero-h1
        data-i18n="hero-h1"
        class="font-bold tracking-tight text-cloud text-3xl sm:text-4xl lg:text-6xl leading-[1.4] drop-shadow-lg mb-6 opacity-0"
      >
        青空が目指しているのは<br />
        「ちょっと驚くサービス」<br />
        の提供です。
      </h1>

      <p
        data-hero-sub
        data-i18n="hero-sub"
        class="text-cloud/70 text-base sm:text-lg lg:text-xl leading-relaxed mb-10 max-w-2xl drop-shadow opacity-0"
      >
        沖縄・東京・ネパール拠点のコスト競争力で、中小企業のWeb課題を解決します。
      </p>

      <div data-hero-ctas class="flex flex-wrap gap-4">
        <a
          href="/contact"
          class="btn-magnetic inline-flex items-center gap-2 rounded-md bg-azure px-7 py-3.5 text-base text-space font-semibold hover:bg-aozora-600 transition-all duration-200 shadow-[0_4px_24px_rgba(255,198,79,0.35)] hover:shadow-[0_6px_30px_rgba(255,198,79,0.5)] hover:-translate-y-px opacity-0"
        >
          <span data-i18n="hero-cta-primary">無料相談はこちら</span>
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#service"
          class="inline-flex items-center gap-2 rounded-md border border-cloud/30 bg-space/70 px-7 py-3.5 text-base text-cloud/85 font-medium hover:bg-space hover:border-cloud/50 hover:text-cloud transition-all duration-200 opacity-0"
        >
          <span data-i18n="hero-cta-secondary">サービスを見る</span>
        </a>
      </div>

      <!-- Scroll indicator -->
      <div data-hero-scroll class="mt-20 flex items-center gap-3 opacity-0">
        <div class="scroll-indicator-arrow">
          <svg class="h-4 w-4 text-cloud/35" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <span class="text-[10px] tracking-[0.22em] text-cloud/30 uppercase">Scroll</span>
      </div>

    </div>
  </div>
</section>
