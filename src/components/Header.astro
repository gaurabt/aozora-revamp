---
const navItems = [
  { label: "About", href: "/#about" },
  { label: "News", href: "/#news" },
  { label: "Service", href: "/#service" },
  { label: "Company", href: "/#company" },
  { label: "Map", href: "/#map" },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
  data-header
>
  <div class="mx-auto max-w-7xl px-6 lg:px-10 h-[72px] flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="株式会社青空 ホームへ">
      <div class="h-9 w-9 rounded-md bg-[#007AFF] grid place-items-center shrink-0 transition-all duration-300 shadow-[0_2px_14px_rgba(0,122,255,0.35)] group-hover:bg-[#006ce0] group-hover:shadow-[0_4px_22px_rgba(0,122,255,0.45)] group-hover:-translate-y-px">
        <svg viewBox="0 0 100 100" class="h-[20px] w-[20px] text-white" fill="currentColor" aria-hidden="true">
          <circle cx="35" cy="42" r="7" />
          <circle cx="65" cy="42" r="7" />
          <path d="M28 62 Q50 82 72 62" stroke="currentColor" stroke-width="7" fill="none" stroke-linecap="round" />
        </svg>
      </div>
      <div class="flex flex-col leading-none gap-[5px]">
        <span class="font-bold text-cloud text-[15px] tracking-wider">Aozora</span>
        <span class="text-cloud/30 text-[9px] tracking-[0.22em] uppercase font-medium">株式会社青空</span>
      </div>
    </a>

    <!-- Divider -->
    <div class="hidden md:block w-px h-5 bg-slate/70 shrink-0"></div>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-0.5 flex-1" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="relative px-3.5 py-2 text-[13px] font-medium text-cloud/55 hover:text-cloud transition-colors duration-200 rounded-sm hover:bg-white/[0.04] group/link"
        >
          {item.label}
          <span class="absolute bottom-1 left-3.5 right-3.5 h-[2px] bg-accent rounded-full scale-x-0 origin-left group-hover/link:scale-x-100 transition-transform duration-200"></span>
        </a>
      ))}
    </nav>

    <!-- CTA + lang toggle + mobile toggle -->
    <div class="flex items-center gap-3">

      <!-- Language toggle (desktop) -->
      <div class="hidden md:flex items-center border border-slate/50 rounded-sm overflow-hidden text-[11px] font-semibold tracking-widest shrink-0" id="lang-switcher-desktop">
        <button
          data-lang-btn="ja"
          class="px-2.5 py-1.5 transition-colors duration-150 text-cloud bg-slate/40 hover:bg-slate/60"
          aria-label="日本語に切り替え"
        >JP</button>
        <span class="w-px h-3 bg-slate/70 shrink-0"></span>
        <button
          data-lang-btn="en"
          class="px-2.5 py-1.5 transition-colors duration-150 text-cloud/40 hover:text-cloud hover:bg-slate/30"
          aria-label="Switch to English"
        >EN</button>
      </div>

      <a
        href="/contact"
        class="hidden md:inline-flex items-center gap-2 rounded-md bg-azure px-5 py-2.5 text-[13px] text-space font-semibold hover:bg-[#E7AE36] transition-all duration-200 shadow-[0_2px_14px_rgba(255,198,79,0.35)] hover:shadow-[0_4px_20px_rgba(255,198,79,0.45)] hover:-translate-y-px"
      >
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 43.64 33.21" fill="currentColor" aria-hidden="true">
          <path d="M38.32,0h-33A5.34,5.34,0,0,0,0,5.34V27.88a5.34,5.34,0,0,0,5.34,5.33h33a5.33,5.33,0,0,0,5.33-5.33V5.35A5.33,5.33,0,0,0,38.32,0Zm2.9,27.88a2.9,2.9,0,0,1-2.9,2.9h-33a2.9,2.9,0,0,1-2.9-2.9V5.35a2.9,2.9,0,0,1,2.9-2.9h33a2.9,2.9,0,0,1,2.9,2.9V27.88Z"/>
          <path d="M27.53,16.33,38.2,6.75a1.22,1.22,0,1,0-1.63-1.81L21.84,18.15,19,15.59a0,0,0,0,1,0,0l-.2-.17L7.07,4.93A1.22,1.22,0,0,0,5.45,6.75l10.8,9.66L5.49,26.48a1.22,1.22,0,0,0,.84,2.11,1.23,1.23,0,0,0,.83-.32L18.08,18.05l3,2.65a1.2,1.2,0,0,0,.81.3,1.22,1.22,0,0,0,.82-.31l3-2.73L36.57,28.27a1.18,1.18,0,0,0,.83.34,1.22,1.22,0,0,0,.84-2.11Z"/>
        </svg>
        <span data-i18n="header-contact">お問い合わせ</span>
      </a>

      <button
        id="mobile-menu-toggle"
        class="md:hidden h-10 w-10 grid place-items-center rounded-md transition-opacity duration-200 hover:opacity-70"
        aria-label="メニューを開く"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="relative block h-5 w-5">
          <svg id="icon-menu" class="absolute inset-0 h-5 w-5 text-cloud" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="absolute inset-0 h-5 w-5 text-cloud" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-slate/40 bg-space/98 backdrop-blur-md"
  >
    <nav class="mx-auto max-w-7xl px-6 py-5 flex flex-col gap-1" aria-label="Mobile navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link px-4 py-3 text-sm font-medium text-cloud/60 hover:text-cloud hover:bg-white/[0.05] rounded-md transition-all duration-200 border border-transparent hover:border-slate/50"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/contact"
        class="mobile-nav-link mt-3 inline-flex items-center justify-center gap-2 rounded-md bg-azure px-5 py-3 text-sm text-space font-semibold hover:bg-[#E7AE36] transition-all duration-200 shadow-[0_2px_14px_rgba(255,198,79,0.35)]"
      >
        <span data-i18n="header-contact">お問い合わせ</span>
      </a>

      <!-- Language toggle (mobile) -->
      <div class="flex items-center gap-2 px-4 pt-3 border-t border-slate/30 mt-1">
        <span class="text-cloud/40 text-xs tracking-widest uppercase">Language</span>
        <div class="flex items-center border border-slate/50 rounded-sm overflow-hidden text-[11px] font-semibold tracking-widest ml-auto">
          <button
            data-lang-btn="ja"
            class="px-2.5 py-1.5 transition-colors duration-150 text-cloud bg-slate/40"
            aria-label="日本語に切り替え"
          >JP</button>
          <span class="w-px h-3 bg-slate/70 shrink-0"></span>
          <button
            data-lang-btn="en"
            class="px-2.5 py-1.5 transition-colors duration-150 text-cloud/40 hover:text-cloud"
            aria-label="Switch to English"
          >EN</button>
        </div>
      </div>
    </nav>
  </div>
</header>

