      "footer-contact-form": "Contact Form",
      "footer-map-link": "View Office Locations",
      "contact-h1": "Contact Us",
      "contact-sub": "Questions, consultations, or estimates — feel free to reach out. Our team will reply within 2 business days.",
      "contact-office-h2": "HQ (Okinawa City)",
      "contact-estimate-title": "Free consultation &amp; estimate",
      "contact-estimate-body": "We'll propose the best approach tailored to your content, scale, and budget. No commitment required.",
      "contact-map-link": "View office locations",
    },
  };

  function applyLang(lang: string) {
    const dict = T[lang] ?? T["ja"];
    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n")!;
      if (dict[key] !== undefined) {
        el.innerHTML = dict[key];
      }
    });
    // Sync toggle buttons
    document.querySelectorAll<HTMLElement>("[data-lang-btn]").forEach((btn) => {
      const isActive = btn.getAttribute("data-lang-btn") === lang;
      if (isActive) {
        btn.classList.add("text-cloud", "bg-slate/40");
        btn.classList.remove("text-cloud/40", "bg-transparent");
      } else {
        btn.classList.remove("text-cloud", "bg-slate/40");
        btn.classList.add("text-cloud/40", "bg-transparent");
      }
    });
    document.documentElement.lang = lang === "en" ? "en" : "ja";
    document.dispatchEvent(new CustomEvent("aozora-lang", { detail: lang }));
  }

  // ── Re-init on every page load (handles Astro View Transitions) ──────────
  document.addEventListener("astro:page-load", () => {
    // Scroll-aware background
    const header = document.querySelector("[data-header]") as HTMLElement | null;
    if (header) {
      const update = () => {
        if (window.scrollY > 16) {
          header.classList.add("bg-space/95", "backdrop-blur-md", "border-b", "border-slate/50", "shadow-[0_1px_40px_rgba(0,0,0,0.5)]");
        } else {
          header.classList.remove("bg-space/95", "backdrop-blur-md", "border-b", "border-slate/50", "shadow-[0_1px_40px_rgba(0,0,0,0.5)]");
        }
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
    }

    // Mobile menu toggle — GSAP animated
    const toggle     = document.getElementById("mobile-menu-toggle") as HTMLButtonElement | null;
    const mobileMenu = document.getElementById("mobile-menu")        as HTMLElement | null;
    const iconMenu   = document.getElementById("icon-menu")          as SVGElement | null;
    const iconClose  = document.getElementById("icon-close")         as SVGElement | null;

    if (toggle && mobileMenu && iconMenu && iconClose) {
      let menuOpen = false;

      // Initialise hidden state via GSAP (overrides any Tailwind hidden class)
      gsap.set(mobileMenu, { display: 'none' });
      gsap.set(iconClose,  { opacity: 0, scale: 0.65, rotate: -90 });
      gsap.set(iconMenu,   { opacity: 1, scale: 1,    rotate: 0   });

      function openMenu() {
        menuOpen = true;
        toggle.setAttribute("aria-expanded", "true");

        // Slide-down panel
        gsap.set(mobileMenu, { display: 'block', height: 0, opacity: 0, overflow: 'hidden' });
        gsap.to(mobileMenu, {
          height: 'auto', opacity: 1,
          duration: 0.42, ease: 'expo.out',
          onComplete: () => gsap.set(mobileMenu, { overflow: '' }),
        });

        // Stagger nav links + lang row
        const links   = Array.from(mobileMenu.querySelectorAll('.mobile-nav-link'));
        const langRow = mobileMenu.querySelector<HTMLElement>('.flex.items-center.gap-2');
        gsap.fromTo(
          langRow ? [...links, langRow] : links,
          { opacity: 0, x: -18 },
          { opacity: 1, x: 0, stagger: 0.05, duration: 0.3, ease: 'power2.out', delay: 0.08 }
        );

        // Icon morph: menu → ✕
        gsap.to(iconMenu,  { opacity: 0, scale: 0.65, rotate: 90,  duration: 0.16, ease: 'power2.in' });
        gsap.to(iconClose, { opacity: 1, scale: 1,    rotate: 0,   duration: 0.22, delay: 0.14, ease: 'back.out(2)' });
      }

      function closeMenu() {
        menuOpen = false;
        toggle.setAttribute("aria-expanded", "false");

        // Slide-up panel
        gsap.set(mobileMenu, { overflow: 'hidden' });
        gsap.to(mobileMenu, {
          height: 0, opacity: 0,
          duration: 0.28, ease: 'power3.in',
          onComplete: () => gsap.set(mobileMenu, { display: 'none', clearProps: 'height,opacity,overflow' }),
        });

        // Icon morph: ✕ → menu
        gsap.to(iconClose, { opacity: 0, scale: 0.65, rotate: 90,  duration: 0.16, ease: 'power2.in' });
        gsap.to(iconMenu,  { opacity: 1, scale: 1,    rotate: 0,   duration: 0.22, delay: 0.14, ease: 'back.out(2)' });
      }

      toggle.addEventListener("click", () => { menuOpen ? closeMenu() : openMenu(); });

      mobileMenu.querySelectorAll(".mobile-nav-link").forEach((link) => {
        link.addEventListener("click", () => { if (menuOpen) closeMenu(); });
      });
    }

    // Smooth anchor scroll via Lenis (home page only)
    if (window.location.pathname === "/") {
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"], a[href^="/#"]').forEach((anchor) => {
        anchor.addEventListener("click", (e) => {
          const href = anchor.getAttribute("href");
          if (!href) return;
          const hash = href.startsWith("/#") ? href.slice(1) : href;
          if (!hash || hash === "#") return;
          const target = document.querySelector(hash);
          if (!target) return;
          e.preventDefault();
          const lenis = (window as any).__lenis;
          if (lenis) {
            lenis.scrollTo(hash, { offset: -72, duration: 1.2 });
          } else {
            const y = target.getBoundingClientRect().top + window.scrollY - 72;
            window.scrollTo({ top: y, behavior: "smooth" });
          }
        });
      });
    }

    // Lang toggle click handlers
    document.querySelectorAll<HTMLElement>("[data-lang-btn]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const lang = btn.getAttribute("data-lang-btn")!;
        localStorage.setItem(LANG_KEY, lang);
        applyLang(lang);
      });
    });

    // Apply stored language to current page content
    applyLang(localStorage.getItem(LANG_KEY) ?? "ja");
  });
</script>
